{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "globalEnv": [
    "AI_GATEWAY_API_KEY",
    "AXIOM_TOKEN",
    "AXIOM_DATASET",
    "OTLP_ENDPOINT",
    "POSTHOG_API_KEY",
    "POSTHOG_HOST",
    "SENTRY_DSN",
    "BETTER_STACK_SOURCE_TOKEN"
  ],
  "globalPassThroughEnv": [
    "CI",
    "GITHUB_ACTIONS",
    "GITHUB_EVENT_NAME",
    "GITHUB_REF",
    "GITHUB_SHA"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".nuxt/**",
        ".output/**",
        ".vercel/output/**",
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "env": [
        "NUXT_STUDIO_SSO_URL",
        "NUXT_STUDIO_SSO_CLIENT_ID",
        "NUXT_STUDIO_SSO_CLIENT_SECRET",
        "AI_GATEWAY_API_KEY",
        "NUXT_SITE_URL",
        "AXIOM_TOKEN"
      ]
    },
    "dev": {
      "dependsOn": ["dev:prepare"],
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "env": [
        "AI_GATEWAY_API_KEY"
      ]
    },
    "dev:prepare": {
      "dependsOn": ["^dev:prepare"],
      "outputs": ["dist/**", ".nuxt/**", ".output/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"]
    },
    "lint": {
      "dependsOn": ["dev:prepare"]
    },
    "lint:fix": {
      "dependsOn": ["dev:prepare"],
      "cache": false
    },
    "bench": {
      "dependsOn": ["^dev:prepare"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^dev:prepare"]
    },
    "typecheck": {
      "dependsOn": ["dev:prepare"]
    }
  }
}
